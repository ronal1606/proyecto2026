@startuml UC_Autenticacion
title AgroVision — Casos de Uso: Módulo de Autenticación

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  ArrowColor #0D47A1
  ActorBackgroundColor #BBDEFB
  ActorBorderColor #1565C0
  FontSize 12
}

' ─────────────────────────── ACTORES ────────────────────────────
actor "Usuario\nNo Autenticado" as UA #LightBlue
actor "Usuario\nAutenticado" as U #LightGreen
actor "Sistema\nde Email (SMTP)" as Email #LightYellow

' ─────────────────────────── SISTEMA ────────────────────────────
rectangle "Módulo de Autenticación" {

  usecase "UC01 — Iniciar Sesión" as UC01
  note right of UC01
    Flujo normal:
    1. Ingresar usuario y contraseña
    2. Sistema valida credenciales
    3. Si válido → genera OTP (6 dígitos)
    4. Redirige a verificación 2FA
    Flujo alternativo:
    • Credenciales inválidas → mensaje error
    • Usuario inactivo → mensaje error
  end note

  usecase "UC02 — Registrarse" as UC02
  note right of UC02
    Precondición: no estar autenticado
    Flujo:
    1. Completar formulario (usuario,
       email, nombre, contraseña)
    2. Sistema valida unicidad de
       usuario y email
    3. Crea User + UserProfile (rol=user)
    Extensión:
    • Contraseñas no coinciden → error
    • Usuario/email duplicado → error
  end note

  usecase "UC03 — Verificar Código 2FA" as UC03

  usecase "UC03a — Generar OTP de\n6 Dígitos" as UC03a

  usecase "UC03b — Enviar OTP\npor Email" as UC03b
  note bottom of UC03b
    Tiempo de expiración: 5 minutos
    Email enmascarado en pantalla
    (ej: r****l@gmail.com)
  end note

  usecase "UC03c — Reenviar\nCódigo OTP" as UC03c

  usecase "UC04 — Cerrar Sesión" as UC04
  note right of UC04
    Precondición: estar autenticado
    Flujo:
    1. Invalida la sesión activa
    2. Redirige a página de login
  end note
}

' ─────────────────────────── RELACIONES ─────────────────────────
UA --> UC01
UA --> UC02
U --> UC04

' 2FA flow
UC01 ..> UC03a : <<include>>
UC03a ..> UC03b : <<include>>
UC03b --> Email
UC01 ..> UC03 : <<include>>
UC03 ..> UC03c : <<extend>>\n[si el usuario\nsolicita reenvío]
UC03c ..> UC03a : <<include>>

@enduml
