@startuml UC_General_AgroVision
title AgroVision — Diagrama General de Casos de Uso

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

skinparam usecase {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
  ArrowColor #1B5E20
  ActorBackgroundColor #C8E6C9
  ActorBorderColor #2E7D32
  FontSize 12
}

' ─────────────────────────── ACTORES ────────────────────────────
actor "Usuario\nNo Autenticado" as UA #LightBlue
actor "Usuario\nAutenticado" as U #LightGreen
actor "Administrador" as Admin #LightCoral
actor "Sistema\nde Email" as Email #LightYellow

Admin -|> U : hereda

' ─────────────────────────── SISTEMA ────────────────────────────
rectangle "AgroVision — Sistema de Gestión de Modelos ML Agrícolas" {

  package "Autenticación" {
    usecase "Iniciar Sesión" as UC01
    usecase "Registrarse" as UC02
    usecase "Verificar Código 2FA" as UC03
    usecase "Cerrar Sesión" as UC04
    usecase "Generar y Enviar OTP" as UC03a
  }

  package "Panel Principal" {
    usecase "Ver Dashboard" as UC05
    usecase "Ver Página Nosotros" as UC06
  }

  package "Gestión de Modelos ML\n(solo Administrador)" {
    usecase "Ver Catálogo de Modelos" as UC07
    usecase "Crear Modelo ML" as UC08
    usecase "Ver Detalle de Modelo" as UC09
    usecase "Editar Modelo ML" as UC10
    usecase "Eliminar Modelo ML" as UC11
    usecase "Buscar / Filtrar Modelos" as UC12
  }

  package "Inferencia de Modelos" {
    usecase "Ejecutar Inferencia\nsobre Imagen" as UC13
    usecase "Subir Imagen" as UC14
    usecase "Preprocesar Imagen" as UC15
    usecase "Guardar Resultado\nen Historial" as UC16
  }

  package "Historial de Ejecuciones" {
    usecase "Ver Historial" as UC17
    usecase "Ver Detalle\nde Ejecución" as UC18
    usecase "Eliminar Entrada\nde Historial" as UC19
  }
}

' ─────────────────────────── RELACIONES ─────────────────────────

' Usuario No Autenticado
UA --> UC01
UA --> UC02

' Flujo 2FA
UC01 ..> UC03 : <<include>>
UC03 ..> UC03a : <<include>>
UC03a --> Email

' Usuario Autenticado
U --> UC04
U --> UC05
U --> UC06
U --> UC07
U --> UC09
U --> UC12
U --> UC13
U --> UC17
U --> UC18

' Flujo de inferencia
UC13 ..> UC14 : <<include>>
UC13 ..> UC15 : <<include>>
UC13 ..> UC16 : <<include>>

' Administrador (funciones adicionales)
Admin --> UC08
Admin --> UC10
Admin --> UC11
Admin --> UC19

' Búsqueda incluida en catálogo
UC07 ..> UC12 : <<include>>

@enduml
