@startuml UC_Historial
title AgroVision — Casos de Uso: Historial de Ejecuciones

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

skinparam usecase {
  BackgroundColor #F3E5F5
  BorderColor #6A1B9A
  ArrowColor #4A148C
  ActorBackgroundColor #E1BEE7
  ActorBorderColor #6A1B9A
  FontSize 12
}

' ─────────────────────────── ACTORES ────────────────────────────
actor "Usuario\nAutenticado" as U #LightGreen
actor "Administrador" as Admin #LightCoral

Admin -|> U : hereda

' ─────────────────────────── SISTEMA ────────────────────────────
rectangle "Módulo de Historial de Ejecuciones" {

  usecase "UC30 — Ver Historial\nde Ejecuciones" as UC30
  note right of UC30
    Usuario: ve solo sus propias ejecuciones
    Administrador: ve las ejecuciones de
    todos los usuarios del sistema.
    Incluye paginación configurable:
    5, 10 o 25 registros por página.
    Columnas: modelo, ubicación,
    resultado, fecha.
  end note

  usecase "UC31 — Paginar\nHistorial" as UC31
  note right of UC31
    El usuario puede seleccionar
    cuántos registros ver por página:
    • 5 por página
    • 10 por página
    • 25 por página
  end note

  usecase "UC32 — Ver Detalle\nde Ejecución" as UC32
  note right of UC32
    Muestra registro completo:
    • Imagen original subida
    • Modelo utilizado
    • Resultado completo (clase + confianza)
    • Ubicación / campo
    • Fecha y hora exacta
    • Usuario que ejecutó
    Acceso: usuario ve solo sus propias;
    admin puede ver cualquiera.
  end note

  usecase "UC33 — Eliminar Entrada\nde Historial" as UC33
  note right of UC33
    Precondición: el registro debe existir.
    Al eliminar:
    1. Elimina el registro de la BD
    2. Elimina la imagen del almacenamiento
       (local o Azure Blob)
    Acceso:
    • Usuario: solo sus propios registros
    • Admin: cualquier registro
  end note

  usecase "UC34 — Descargar /\nVer Imagen Subida" as UC34
  note right of UC34
    Desde el detalle de ejecución,
    el usuario puede ver o descargar
    la imagen original que subió
    para la inferencia.
  end note
}

' ─────────────────────────── RELACIONES ─────────────────────────
U --> UC30
U --> UC32
U --> UC33
U --> UC34

UC30 ..> UC31 : <<include>>
UC32 ..> UC34 : <<extend>>\n[si el usuario\ndesea ver imagen]

Admin --> UC30
Admin --> UC32
Admin --> UC33

@enduml
